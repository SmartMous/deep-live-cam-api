# Deep-Live-Cam root directory
DEEP_LIVE_CAM_PATH=/tmp/Deep-Live-Cam

# Execution provider: cuda, cpu, coreml, rocm, dml
EXECUTION_PROVIDER=cuda

# Max memory in GB (None = auto)
MAX_MEMORY=

# Execution threads for CPU
EXECUTION_THREADS=

# CORS origins (comma-separated, or "*" for all)
CORS_ORIGINS=*

# Output directory
OUTPUT_DIR=/tmp/deep-live-cam-api/outputs

# Log level: debug, info, warning, error
LOG_LEVEL=error
